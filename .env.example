# Red: alfajores (testnet, default) | celo (mainnet)
NETWORK=alfajores

# Wallet del agente (servidor). NUNCA commitear la real.
AGENT_PRIVATE_KEY=

# Wallet del bot de Telegram (segunda wallet, distinta a la del agente)
BOT_PRIVATE_KEY=

# Attribution tag del hackathon (lo entrega el registro en celobuilders.xyz)
ATTRIBUTION_TAG=

# Token del bot (@BotFather)
TELEGRAM_BOT_TOKEN=

# URL pública del backend (para el bot y la landing)
API_BASE_URL=http://localhost:3000

# Puerto del backend
PORT=3000
