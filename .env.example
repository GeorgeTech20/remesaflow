# Red: celo-sepolia (testnet, default) | celo (mainnet). Alfajores esta DEPRECADO.
NETWORK=celo-sepolia

# RPC override opcional (Forno es rate-limited; alternativas: https://rpc.ankr.com/celo, https://celo.drpc.org)
RPC_URL=

# Motor de cotizacion: mock | mento | auto (default auto: mento si el RPC responde, mock si no)
QUOTE_ENGINE=auto

# Wallet del agente (servidor). NUNCA commitear la real. Sin ella: modo degradado read-only.
AGENT_PRIVATE_KEY=

# Wallet del bot de Telegram (segunda wallet, distinta a la del agente)
BOT_PRIVATE_KEY=

# Attribution tag ERC-8021 (ej. "remesaflow" o el codigo celo_xxx del hackathon).
# En mainnet es OBLIGATORIO para enviar tx.
ATTRIBUTION_TAG=

# x402: true = cobra $0.01 USDC por /api/quote (requiere AGENT_PRIVATE_KEY)
X402_ENABLED=false

# API key para POST /settle en api.x402.celo.org (ver ACCION_HUMANA_REQUERIDA.md).
# Sin ella: modo degradado verify-only (verifica pagos pero no settlea on-chain).
X402_FACILITATOR_API_KEY=

# Token del bot (@BotFather)
TELEGRAM_BOT_TOKEN=

# URL publica del backend (para el bot y la landing)
API_BASE_URL=http://localhost:3000

# Puerto del backend
PORT=3000
