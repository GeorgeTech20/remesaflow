# Red: celo-sepolia (testnet, default) | celo (mainnet). Alfajores esta DEPRECADO.
NETWORK=celo-sepolia

# RPC override opcional (Forno es rate-limited; alternativas: https://rpc.ankr.com/celo, https://celo.drpc.org)
RPC_URL=

# Motor de cotizacion: mock | mento | auto (default auto: mento si el RPC responde, mock si no)
QUOTE_ENGINE=auto

# Wallet del agente (servidor). NUNCA commitear la real. Sin ella: modo degradado read-only.
AGENT_PRIVATE_KEY=

# Wallet del bot de Telegram (segunda wallet, distinta a la del agente)
BOT_PRIVATE_KEY=

# Attribution tag ERC-8021 (ej. "remesaflow" o el codigo celo_xxx del hackathon).
# En mainnet es OBLIGATORIO para enviar tx.
ATTRIBUTION_TAG=

# x402: true = cobra $0.01 USDC por /api/quote (requiere AGENT_PRIVATE_KEY)
X402_ENABLED=false

# API key para POST /settle en el facilitador x402 (self-serve en x402.celo.org).
# Sin ella: modo degradado verify-only (verifica pagos pero no settlea on-chain).
X402_FACILITATOR_API_KEY=

# Demo de la landing (F8): true = expone POST /api/demo/quote (5 consultas/IP/24h).
# El servidor paga su PROPIO endpoint x402 con DEMO_PRIVATE_KEY (wallet distinta
# a AGENT_PRIVATE_KEY: esta PAGA, la del agente COBRA). Sin la key y con
# X402_ENABLED=true, la demo responde 503.
DEMO_MODE=false
DEMO_PRIVATE_KEY=

# ---------------------------------------------------------------------------
# F-EXEC — ejecucion de remesas REALES (POST /api/remit).
#
# Esto mueve dinero de verdad. Todos los limites son guardrails, no sugerencias.
# Ver backend/README.md (seccion F-EXEC) para el diseno de tx y el detalle.
# ---------------------------------------------------------------------------

# Kill switch. false (default) = POST /api/remit devuelve 503 y NO se mueve nada.
# Ponerlo en true es una decision explicita: a partir de ahi el agente paga de verdad.
# Ademas de esto, ejecutar necesita el motor Mento (RPC con rutas) + AGENT_PRIVATE_KEY.
REMIT_ENABLED=false

# Monto maximo por remesa, en USD. Superarlo = 400. (default 25)
REMIT_MAX_USD=25

# Tope diario acumulado del agente (UTC), en USD. Superarlo = 429. (default 100)
# El contador se reconstruye desde logs/remits.jsonl al arrancar:
# reiniciar el server NO resetea el limite.
REMIT_DAILY_CAP_USD=100

# Slippage maximo tolerado, en %. Si la tasa se movio mas que esto en contra del
# destinatario, se aborta SIN ejecutar (409) y se devuelve la tasa nueva.
# Tambien se aplica on-chain como amountOutMin del swap. (default 1)
REMIT_MAX_SLIPPAGE_PCT=1

# Token del bot (@BotFather)
TELEGRAM_BOT_TOKEN=

# URL publica del backend (para el bot y la landing)
API_BASE_URL=http://localhost:3000

# ERC-8004: URL del registration file del agente. Default:
# <API_BASE_URL>/agent-registration.json (lo sirve el propio backend).
# Solo override si se hostea aparte (ej. ipfs://...).
AGENT_REGISTRATION_URL=

# Puerto del backend
PORT=3000
